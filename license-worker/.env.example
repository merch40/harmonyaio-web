# Local development env vars consumed by `wrangler dev`.
# Copy to .dev.vars (gitignored) and fill in real values.

# Base64-encoded ed25519 private key (64-byte standard encoding).
# In tests this is read from dev.secrets.json instead.
HARMONY_LICENSE_SIGNING_KEY_V1=

# 32+ byte secret used to HMAC magic-link session cookies.
SESSION_SECRET=please-change-me-please-change-me

# Header value required for POST /admin/license calls.
ADMIN_SECRET=dev-admin-secret

# Brevo integration (deferred per sprint brief §17 — leave blank).
BREVO_API_KEY=
